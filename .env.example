# ── Supabase (Project Settings → API) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # anon public key

# ⚠️ SOLO en el servidor. Nunca con prefijo NEXT_PUBLIC_. No la subas a git.
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # service_role secret key

# ── Salesforce (validación de casos informativos) ──────────────────
# Mismas credenciales que usa Pulso / mayoristas-tracker (login SOAP + token).
SF_USERNAME=tu_usuario@etb.com.co
SF_PASSWORD=tu_contraseña_sf
SF_TOKEN=tu_token_de_seguridad_sf
SF_DOMAIN=login                            # 'login' (prod) o 'test' (sandbox)

# URL pública del sitio (para enlaces de recuperación de contraseña).
NEXT_PUBLIC_SITE_URL=https://reporting-desk.vercel.app
